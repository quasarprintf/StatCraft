<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StatCraft.ViewModels"
             x:Class="StatCraft.Views.BuildsPage"
             x:DataType="vm:BuildsPageViewModel">
    <DockPanel>
        <!-- Matchup buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="4">
            <Button Content="vs P" Command="{Binding SelectVsPCommand}" Classes.active="{Binding IsVsP}"/>
            <Button Content="vs T" Command="{Binding SelectVsTCommand}" Classes.active="{Binding IsVsT}"/>
            <Button Content="vs Z" Command="{Binding SelectVsZCommand}" Classes.active="{Binding IsVsZ}"/>
        </StackPanel>

        <!-- Left/right split -->
        <Grid ColumnDefinitions="200,4,*">
            <!-- Build tree -->
            <TreeView Grid.Column="0" ItemsSource="{Binding Builds}" SelectedItem="{Binding SelectedBuild}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>

            <!-- Build form: left details + right description -->
            <Grid Grid.Column="2" ColumnDefinitions="*,4,*">

                <!-- Left: Name + attributes -->
                <DockPanel Grid.Column="0" Margin="12">
                    <StackPanel DockPanel.Dock="Top" Spacing="6">
                        <TextBlock Text="Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SelectedBuild.Name}"/>
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock Text="Attributes" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="+" DockPanel.Dock="Right"
                                    Command="{Binding AddAttributeCommand}"
                                    Padding="6,2" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding SelectedBuild.Attributes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BuildAttribute">
                                    <StackPanel Margin="0,0,0,4">
                                        <!-- Main attribute row -->
                                        <Grid ColumnDefinitions="*,120,*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding Name}" PlaceholderText="Name" Margin="0,0,4,0"/>
                                            <ComboBox Grid.Column="1" SelectedItem="{Binding Type}"
                                                      ItemsSource="{x:Static vm:BuildAttribute.AllTypes}"
                                                      HorizontalAlignment="Stretch" Margin="0,0,4,0"/>
                                            <Panel Grid.Column="2">
                                                <NumericUpDown IsVisible="{Binding IsNumeric}"
                                                               Value="{Binding NumericValue}"
                                                               FormatString="0" Increment="1"/>
                                                <CheckBox IsVisible="{Binding IsBool}"
                                                          IsChecked="{Binding BoolValue}"
                                                          VerticalAlignment="Center"/>
                                                <NumericUpDown IsVisible="{Binding IsPercent}"
                                                               Value="{Binding PercentValue}"
                                                               Minimum="0" Maximum="1" Increment="0.01"
                                                               FormatString="0.00"/>
                                                <ComboBox IsVisible="{Binding IsValues}"
                                                          ItemsSource="{Binding ValueOptions}"
                                                          SelectedItem="{Binding SelectedValue}"
                                                          HorizontalAlignment="Stretch"/>
                                            </Panel>
                                            <Button Grid.Column="3" Content="✕"
                                                    Command="{Binding $parent[UserControl].((vm:BuildsPageViewModel)DataContext).RemoveAttributeCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,2" Margin="4,0,0,0"/>
                                        </Grid>
                                        <!-- Options editor (Values type only) -->
                                        <StackPanel IsVisible="{Binding IsValues}" Margin="16,4,0,0" Spacing="2">
                                            <ItemsControl ItemsSource="{Binding ValueOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                                                            <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1" Content="✕" Padding="4,1"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.RemoveOptionCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                                <TextBox Grid.Column="0" Text="{Binding NewOptionText}"
                                                         PlaceholderText="Add option..." Margin="0,0,4,0"/>
                                                <Button Grid.Column="1" Content="+" Padding="6,2"
                                                        Command="{Binding AddOptionCommand}"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>

                <!-- Right: Description -->
                <DockPanel Grid.Column="2" Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="Description" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SelectedBuild.Description}" AcceptsReturn="True" TextWrapping="Wrap"/>
                </DockPanel>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
