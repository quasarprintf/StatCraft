<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StatCraft.ViewModels"
        x:Class="StatCraft.Views.SettingsPromptWindow"
        x:DataType="vm:SettingsPromptViewModel"
        Title="StatCraft Setup"
        Width="480" Height="220"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Set Replay Folder" FontWeight="SemiBold"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray">
            StatCraft needs to know where your StarCraft II replays are stored before continuing. 
            On Windows, this is typically 
            <LineBreak />
            C:\Users\{user}\Documents\StarCraft II
        </TextBlock>

        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Grid.Column="0" Text="{Binding BaseReplayFolderPath}" Margin="0,0,4,0"/>
            <Button Grid.Column="1" Content="Browse..." Click="OnBrowseClick"/>
        </Grid>

        <Button Content="Continue" Command="{Binding ContinueCommand}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,8,0,0"/>
    </StackPanel>
</Window>
