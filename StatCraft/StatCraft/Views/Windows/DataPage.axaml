<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StatCraft.ViewModels"
             x:Class="StatCraft.Views.DataPage"
             x:DataType="vm:DataPageViewModel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="{Binding ActiveProfileLabel}" FontSize="20" HorizontalAlignment="Center"/>
        <Button Content="Begin Session" Command="{Binding BeginSessionCommand}" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
