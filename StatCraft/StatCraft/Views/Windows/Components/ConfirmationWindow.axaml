<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StatCraft.Views.ConfirmationWindow"
        Title="Confirm"
        Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="OnCancelClick"/>
            <Button Content="Confirm" Click="OnConfirmClick"/>
        </StackPanel>
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" VerticalAlignment="Center"/>
    </DockPanel>
</Window>
